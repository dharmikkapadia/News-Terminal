# Copy to .streamlit/secrets.toml (for Streamlit Cloud) OR export these as
# environment variables (for the poller on a VM / GitHub Actions).
# Every channel is optional — set only the ones you want.

# --- Slack (Incoming Webhook) ---
# SLACK_WEBHOOK_URL = "https://hooks.slack.com/services/XXX/YYY/ZZZ"

# --- Telegram (create a bot via @BotFather, then get your chat id) ---
# TELEGRAM_BOT_TOKEN = "123456:ABC-DEF..."
# TELEGRAM_CHAT_ID   = "987654321"

# --- Email (SMTP) ---
# SMTP_HOST       = "smtp.gmail.com"
# SMTP_PORT       = "587"
# SMTP_USER       = "you@example.com"
# SMTP_PASS       = "app-password"
# ALERT_EMAIL_TO  = "desk@example.com, you@example.com"
# ALERT_EMAIL_FROM= "marketwire@example.com"

# --- Tuning (optional) ---
# MARKETWIRE_ALERT_SCORE = "9"   # also alert on high-scoring items with no watchlist hit
# MARKETWIRE_DB = "/var/lib/marketwire/marketwire.db"
